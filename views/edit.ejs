<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class ="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class ="flex justify-end w-full">   
             <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>

        
        <h5 class="mb-5"> Edit your  post </h5>
        <form action="/update/<%= post._id %>" method="post" class="flex flex-col gap-3 mt-5">

            <textarea name="content" placeholder="What's on your mind" class="p-2 rounded bg-zinc-800 focus:outline-none"><%= post.content %></textarea>
            <input type="submit" class="bg-yellow-500  text-black py-2 px-3 w-40 rounded-md mt-2 text-sm block" value="Update Post">
        </form> 

        

       


    </div>
    
</body>
</html>